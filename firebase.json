{
  "_comment": "Configuración de despliegue para Firebase Hosting. Indica que la carpeta pública a subir es 'dist' y asegura que todas las URLs redirijan a index.html (esencial para Single Page Apps como React).",
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.DBF",
        "headers": [
          {
            "key": "Access-Control-Allow-Origin",
            "value": "*"
          }
        ]
      }
    ]
  }
  ,
  "firestore": {
    "rules": "firestore.rules"
  }
}
